# ═══════════════════════════════════════
# MendesERP — Variáveis de Ambiente
# Copiar para .env e preencher os valores
# ═══════════════════════════════════════

# ─── BANCO DE DADOS ───
POSTGRES_USER=mendes
POSTGRES_PASSWORD=           # OBRIGATÓRIO — senha forte
POSTGRES_DB=erp_mendes
DATABASE_URL=postgresql://mendes:SENHA@postgres:5432/erp_mendes?schema=public

# ─── REDIS ───
REDIS_URL=redis://redis:6379

# ─── SEGURANÇA (gerar com: openssl rand -hex 32) ───
JWT_SECRET=                  # OBRIGATÓRIO
REFRESH_SECRET=              # OBRIGATÓRIO
ENCRYPTION_KEY=              # OBRIGATÓRIO

# ─── WHATSAPP SERVICE ───
WHATSAPP_SERVICE_URL=http://whatsapp-service:3001
WHATSAPP_SERVICE_API_KEY=    # Chave aleatória forte
FILE_TOKEN_SECRET=           # Recomendado em produção: secret separado para links assinados de arquivos (evita compartilhar API_KEY)
WHATSAPP_WEBHOOK_SECRET=     # Chave aleatória forte
WHATSAPP_CORS_ORIGIN=https://erp.seudominio.com.br

# ─── IA (opcional) ───
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_EMBEDDING_PROVIDER=openai
AI_EMBEDDING_KEY=
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_TIMEOUT=30000

# ─── RAG ───
RAG_CHUNK_SIZE=500
RAG_MAX_RESULTS=5
RAG_SIMILARITY_THRESHOLD=0.7
