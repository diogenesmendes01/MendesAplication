# Database connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/erp_mendes?schema=public"

# JWT secrets (change in production!)
JWT_SECRET="your-jwt-secret-here"
REFRESH_SECRET="your-refresh-secret-here"

# Redis (used by BullMQ for background job queues)
REDIS_URL="redis://localhost:6379"

# WhatsApp Service (Baileys microservice)
# Start with: docker compose up -d whatsapp-service
WHATSAPP_SERVICE_URL="http://localhost:3001"
WHATSAPP_SERVICE_API_KEY="your-whatsapp-service-api-key"
WHATSAPP_WEBHOOK_SECRET="your-webhook-secret"

# AI Agent - LLM Provider (openai | deepseek | anthropic)
AI_PROVIDER="openai"
AI_API_KEY="your-ai-api-key"
AI_MODEL=""
AI_TIMEOUT="30000"

# AI Agent - Embeddings
AI_EMBEDDING_PROVIDER="openai"
AI_EMBEDDING_KEY="your-embedding-api-key"
AI_EMBEDDING_MODEL=""

# AI Agent - RAG Configuration
RAG_CHUNK_SIZE="500"
RAG_MAX_RESULTS="5"
RAG_SIMILARITY_THRESHOLD="0.7"

# Encryption key for channel config passwords (32 hex chars = 16 bytes for AES-128)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef"
