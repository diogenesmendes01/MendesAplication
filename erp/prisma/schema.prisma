generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
}

enum Status {
  ACTIVE
  INACTIVE
}

enum ClientType {
  PF
  PJ
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

enum FinancialCategoryType {
  INCOME
  EXPENSE
}

enum Recurrence {
  NONE
  WEEKLY
  MONTHLY
  YEARLY
}

model Company {
  id                String   @id @default(cuid())
  razaoSocial       String
  nomeFantasia      String
  cnpj              String   @unique
  inscricaoEstadual String?
  endereco          String?
  telefone          String?
  email             String?
  segmento          String?
  logoUrl           String?
  status            Status   @default(ACTIVE)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  userCompanies      UserCompany[]
  auditLogs          AuditLog[]
  clients            Client[]
  financialCategories FinancialCategory[]
  accountsReceivable AccountReceivable[]
  accountsPayable    AccountPayable[]
  bankTransactions   BankTransaction[]

  @@map("companies")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(MANAGER)
  status       Status   @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userCompanies      UserCompany[]
  auditLogs          AuditLog[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model UserCompany {
  userId    String
  companyId String
  modules   String[]

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@map("user_companies")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entity     String
  entityId   String
  dataBefore Json?
  dataAfter  Json?
  ipAddress  String?
  companyId  String?
  createdAt  DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Client {
  id           String     @id @default(cuid())
  name         String
  razaoSocial  String?
  cpfCnpj      String
  email        String?
  telefone     String?
  endereco     String?
  type         ClientType @default(PF)
  companyId    String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountsReceivable AccountReceivable[]

  @@unique([cpfCnpj, companyId])
  @@map("clients")
}

model FinancialCategory {
  id        String                @id @default(cuid())
  name      String
  type      FinancialCategoryType
  companyId String

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountsPayable AccountPayable[]

  @@map("financial_categories")
}

model AccountReceivable {
  id          String        @id @default(cuid())
  clientId    String
  description String
  value       Decimal       @db.Decimal(12, 2)
  dueDate     DateTime
  status      PaymentStatus @default(PENDING)
  paidAt      DateTime?
  companyId   String
  createdAt   DateTime      @default(now())

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("accounts_receivable")
}

model AccountPayable {
  id          String        @id @default(cuid())
  supplier    String
  description String
  value       Decimal       @db.Decimal(12, 2)
  dueDate     DateTime
  status      PaymentStatus @default(PENDING)
  categoryId  String?
  recurrence  Recurrence    @default(NONE)
  paidAt      DateTime?
  companyId   String
  createdAt   DateTime      @default(now())

  category FinancialCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  company  Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("accounts_payable")
}

enum BankTransactionStatus {
  PENDING
  RECONCILED
}

model BankTransaction {
  id          String                @id @default(cuid())
  date        DateTime
  description String
  value       Decimal               @db.Decimal(12, 2)
  status      BankTransactionStatus @default(PENDING)
  companyId   String
  createdAt   DateTime              @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("bank_transactions")
}
