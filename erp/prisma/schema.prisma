// ─── AI Suggestion Mode ──────────────────────────────────────────────────────

enum AiSuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  EDITED
  EXPIRED
  PROCESSING
}

model AiSuggestion {
  id        String      @id @default(cuid())
  ticketId  String
  messageId String? // Inbound TicketMessage that triggered the suggestion
  companyId String
  channel   ChannelType // WHATSAPP | EMAIL | RECLAMEAQUI

  // ─── Agent analysis ───
  analysis Json // { intent, toolsExecuted, iterationsUsed, searchResults, ... }

  // ─── Suggested response ───
  suggestedResponse String  @db.Text
  suggestedSubject  String? // Email subject (if channel=EMAIL)

  // ─── Suggested actions ───
  suggestedActions Json // Array of { toolName, args, order }

  // ─── Reclame Aqui specific ───
  raPrivateMessage    String? @db.Text
  raPublicMessage     String? @db.Text
  raDetectedType      String?
  raSuggestModeration Boolean @default(false)

  // ─── Status ───
  status          AiSuggestionStatus @default(PENDING)
  reviewedBy      String?
  reviewedAt      DateTime?
  editedResponse  String?            @db.Text
  editedSubject   String?
  rejectionReason String?

  // ─── Execution result ───
  executionResult Json? // { success, toolResults, executedAt, error? }

  // ─── Confidence ───
  confidence Float @default(0.5)

  // ─── Timestamps ───
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?

  // ─── Relations ───
  ticket   Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message  TicketMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reviewer User?          @relation("SuggestionReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  feedbacks AiFeedback[]

  @@index([ticketId, status])
  @@index([companyId, status, createdAt])
  @@index([status, expiresAt])
  @@index([reviewedBy])
  @@map("ai_suggestions")
}

