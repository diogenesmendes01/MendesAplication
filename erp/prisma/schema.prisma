model AiConfig {
  id        String       @id @default(cuid())
  companyId String
  channel   ChannelType? // NULL = global default, set = channel-specific override

  // --- Existentes ---
  enabled            Boolean  @default(false)
  persona            String?  @db.Text
  welcomeMessage     String?  @db.Text
  escalationKeywords String[]
  maxIterations      Int      @default(5)

  // --- Provider ---
  provider   String  @default("openai")
  apiKey     String? @db.Text
  apiKeyHint String? // Last 4 chars of plaintext API key for display
  model      String?

  // --- Canais ---
  whatsappEnabled Boolean @default(true)
  emailEnabled    Boolean @default(false)
  emailPersona    String? @db.Text
  emailSignature  String? @db.Text

  // --- Reclame Aqui ---
  raEnabled               Boolean  @default(false)
  raMode                  String   @default("suggest") // "suggest" | "auto" | "off"
  raPrivateBeforePublic   Boolean  @default(true)
  raAutoRequestEvaluation Boolean  @default(false)
  raEscalationKeywords    String[] @default(["processo", "advogado", "procon", "judicial", "indenização"])

  // Per-channel tool toggles.
  // Semantics: empty array = all tools enabled (backward-compatible default).
  // Populated only when an admin explicitly restricts tools for that channel.
  // The agent (getToolsForChannel) reads these at runtime and filters accordingly.
  // Always-on tools (GET_HISTORY, ESCALATE, RESPOND*) are never filtered out.
  whatsappEnabledTools  String[]
  emailEnabledTools     String[]
  raEnabledTools        String[]

  // --- Modo de Operação (suggestion mode) ---
  operationMode         String   @default("auto") // "auto" | "suggest" | "hybrid"
  hybridThreshold       Float    @default(0.8) // Confidence threshold for hybrid mode (0.0-1.0)
  alwaysRequireApproval String[] @default([]) // Tool names that always require approval
  suggestionTimeoutMin  Int      @default(60) // Minutes until notification about unreviewed suggestion

  // --- Limites ---
  dailySpendLimitBrl Decimal? @db.Decimal(10, 2)

  // --- Rate Limiting ---
  maxAiInteractionsPerTicketPerHour Int      @default(5)
  aiCooldownSeconds                 Int      @default(30)
  maxBudgetPerTicketBrl             Decimal? @default(2.00) @db.Decimal(10, 2)
  rateLimitAction                   String   @default("pause") // "pause" | "escalate"

  // --- Temperatura ---
  temperature Float @default(0.7)
  auditTrailEnabled     Boolean @default(true)
  auditRetentionDays    Int     @default(90)
  auditReasoningEnabled Boolean @default(true)

  // --- AI Fallback ---
  fallbackChain         Json?
  healthCheckEnabled    Boolean   @default(true)
  healthCheckIntervalMs Int       @default(120000)
  humanOnlyModeEnabled  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  usageLogs AiUsageLog[]

  @@unique([companyId, channel]) // For non-null channels; see migration for NULL partial index
  @@map("ai_config")
}

model AiUsageLog {
  id           String   @id @default(cuid())
  aiConfigId   String
  companyId    String
  provider     String
  model        String
  channel      String
  inputTokens  Int
  outputTokens Int
  costUsd      Decimal  @db.Decimal(10, 6)
  costBrl      Decimal  @db.Decimal(10, 4)
