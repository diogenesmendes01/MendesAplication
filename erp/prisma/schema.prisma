generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
}

enum Status {
  ACTIVE
  INACTIVE
}

enum ClientType {
  PF
  PJ
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum FinancialCategoryType {
  INCOME
  EXPENSE
}

enum Recurrence {
  NONE
  WEEKLY
  MONTHLY
  YEARLY
}

model SharedClientGroup {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  companies Company[]

  @@map("shared_client_groups")
}

model Company {
  id                    String   @id @default(cuid())
  razaoSocial           String
  nomeFantasia          String
  cnpj                  String   @unique
  inscricaoEstadual     String?
  endereco              String?
  telefone              String?
  email                 String?
  segmento              String?
  logoUrl               String?
  status                Status   @default(ACTIVE)
  sharedClientGroupId   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  sharedClientGroup  SharedClientGroup? @relation(fields: [sharedClientGroupId], references: [id], onDelete: SetNull)
  userCompanies      UserCompany[]
  auditLogs          AuditLog[]
  clients            Client[]
  financialCategories FinancialCategory[]
  accountsReceivable AccountReceivable[]
  accountsPayable    AccountPayable[]
  bankTransactions   BankTransaction[]
  tickets            Ticket[]
  proposals          Proposal[]
  boletos            Boleto[]
  invoices           Invoice[]
  taxEntries         TaxEntry[]
  chartOfAccounts    ChartOfAccounts[]
  channels           Channel[]
  slaConfigs         SlaConfig[]
  refunds            Refund[]
  baileysAuthStates  BaileysAuthState[]
  lidMappings        LidMapping[]
  aiConfigs          AiConfig[]
  aiUsageLogs        AiUsageLog[]
  documents          Document[]
  fiscalConfig       FiscalConfig?
  paymentProviders   PaymentProvider[]
  santanderSequences SantanderSequence[]

  @@map("companies")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(MANAGER)
  status       Status   @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userCompanies       UserCompany[]
  auditLogs           AuditLog[]
  passwordResetTokens PasswordResetToken[]
  assignedTickets     Ticket[]        @relation("TicketAssignee")
  ticketMessages      TicketMessage[] @relation("TicketMessageSender")
  refundsRequested    Refund[]        @relation("RefundRequestedBy")
  refundsApproved     Refund[]        @relation("RefundApprovedBy")
  refundsExecuted     Refund[]        @relation("RefundExecutedBy")
  refundAttachments   RefundAttachment[]

  @@map("users")
}

model UserCompany {
  userId    String
  companyId String
  modules   String[]

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@map("user_companies")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entity     String
  entityId   String
  dataBefore Json?
  dataAfter  Json?
  ipAddress  String?
  companyId  String?
  createdAt  DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@map("audit_logs")
}

model Client {
  id           String     @id @default(cuid())
  name         String
  razaoSocial  String?
  cpfCnpj      String
  email        String?
  telefone     String?
  endereco     String?
  type         ClientType @default(PF)
  companyId    String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  company            Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountsReceivable AccountReceivable[]
  tickets            Ticket[]
  proposals          Proposal[]
  invoices           Invoice[]
  additionalContacts AdditionalContact[]

  @@unique([cpfCnpj, companyId])
  @@index([companyId])
  @@index([cpfCnpj])
  @@index([companyId, createdAt])
  @@map("clients")
}

model AdditionalContact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  role      String?
  email     String?
  whatsapp  String?
  createdAt DateTime @default(now())

  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tickets        Ticket[]
  ticketMessages TicketMessage[] @relation("TicketMessageContact")

  @@index([clientId])
  @@map("additional_contacts")
}

model Channel {
  id              String       @id @default(cuid())
  companyId       String
  type            ChannelType
  name            String
  config          Json
  isActive        Boolean      @default(true)
  lastSyncUid     Int?
  lastSyncUidSent Int?
  lastSyncAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tickets Ticket[]

  @@map("channels")
}

model SlaConfig {
  id                 String          @id @default(cuid())
  companyId          String
  type               SlaType
  priority           TicketPriority?
  stage              String
  deadlineMinutes    Int
  alertBeforeMinutes Int             @default(30)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, type, priority, stage])
  @@map("sla_configs")
}

model FinancialCategory {
  id        String                @id @default(cuid())
  name      String
  type      FinancialCategoryType
  companyId String

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountsPayable AccountPayable[]

  @@map("financial_categories")
}

model AccountReceivable {
  id          String        @id @default(cuid())
  clientId    String
  description String
  value       Decimal       @db.Decimal(12, 2)
  dueDate     DateTime
  status      PaymentStatus @default(PENDING)
  paidAt      DateTime?
  companyId   String
  boletoId    String?
  createdAt   DateTime      @default(now())

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  boleto  Boleto? @relation(fields: [boletoId], references: [id], onDelete: SetNull)

  @@index([companyId, status, dueDate])
  @@index([boletoId])
  @@map("accounts_receivable")
}

model AccountPayable {
  id          String        @id @default(cuid())
  supplier    String
  description String
  value       Decimal       @db.Decimal(12, 2)
  dueDate     DateTime
  status      PaymentStatus @default(PENDING)
  categoryId  String?
  recurrence  Recurrence    @default(NONE)
  paidAt      DateTime?
  companyId   String
  origin      PayableOrigin @default(MANUAL)
  refundId    String?       @unique
  createdAt   DateTime      @default(now())

  category FinancialCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  company  Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  refund   Refund?            @relation(fields: [refundId], references: [id], onDelete: SetNull)

  @@index([companyId, status, dueDate])
  @@map("accounts_payable")
}

enum TicketPriority {
  HIGH
  MEDIUM
  LOW
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CLIENT
  RESOLVED
  CLOSED
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum BoletoStatus {
  GENERATED
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum BankTransactionStatus {
  PENDING
  RECONCILED
}

enum InvoiceStatus {
  PENDING
  ISSUED
  CANCELLED
}

enum TaxType {
  ISS
  PIS
  COFINS
  IRPJ
  CSLL
}

enum TaxStatus {
  PENDING
  PAID
  CANCELLED
}

enum TaxRegime {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum ChannelType {
  EMAIL
  WHATSAPP
  RECLAMEAQUI
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageOrigin {
  SYSTEM
  EXTERNAL
}

enum MessageDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  PENDING_APPROVAL
  DISCARDED
}

enum SlaType {
  TICKET
  REFUND
}

enum RefundStatus {
  AWAITING_APPROVAL
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
}

enum RefundPaymentMethod {
  PIX
  TED
}

enum RefundAttachmentType {
  PAYMENT_PROOF
  REFUND_PROOF
}

enum RefundInvoiceAction {
  CANCEL_INVOICE
  CREDIT_NOTE
  NONE
}

enum PayableOrigin {
  MANUAL
  REFUND
}

enum DocumentStatus {
  PROCESSING
  READY
  ERROR
}

enum InvoiceType {
  STANDARD
  CREDIT_NOTE
}

model BankTransaction {
  id              String                @id @default(cuid())
  date            DateTime
  description     String
  value           Decimal               @db.Decimal(12, 2)
  status          BankTransactionStatus @default(PENDING)
  matchedType     String?
  matchedEntityId String?
  companyId       String
  createdAt       DateTime              @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@map("bank_transactions")
}

model Ticket {
  id             String         @id @default(cuid())
  clientId       String
  subject        String
  description    String
  priority       TicketPriority @default(MEDIUM)
  status         TicketStatus   @default(OPEN)
  assigneeId     String?
  proposalId     String?
  boletoId       String?
  companyId      String
  channelId      String?
  contactId      String?
  slaFirstReply  DateTime?
  slaResolution  DateTime?
  slaBreached    Boolean        @default(false)
  slaAtRisk      Boolean        @default(false)
  tags           String[]       @default([])
  raExternalId              String?
  raStatusId                Int?
  raStatusName              String?
  raCanEvaluate             Boolean    @default(false)
  raCanModerate             Boolean    @default(false)
  raRating                  String?
  raResolvedIssue           Boolean?
  raBackDoingBusiness       Boolean?
  raFrozen                  Boolean    @default(false)
  raConsumerConsideration   String?    @db.Text
  raCompanyConsideration    String?    @db.Text
  aiEnabled      Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  client      Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignee    User?               @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  proposal    Proposal?           @relation("TicketProposal", fields: [proposalId], references: [id], onDelete: SetNull)
  boleto      Boleto?             @relation("TicketBoleto", fields: [boletoId], references: [id], onDelete: SetNull)
  channel     Channel?            @relation(fields: [channelId], references: [id], onDelete: SetNull)
  contact     AdditionalContact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  messages    TicketMessage[]
  attachments Attachment[]        @relation("TicketAttachments")
  refunds     Refund[]

  @@index([companyId, status])
  @@index([companyId, slaBreached])
  @@index([companyId, clientId])
  @@index([companyId, assigneeId])
  @@index([companyId, status, updatedAt])
  @@index([companyId, slaBreached, status])
  @@index([companyId, status, priority])
  @@index([companyId, raExternalId])
  @@map("tickets")
}

model TicketMessage {
  id           String            @id @default(cuid())
  ticketId     String
  senderId     String?
  content      String
  sentViaEmail Boolean           @default(false)
  channel      ChannelType?
  direction    MessageDirection  @default(OUTBOUND)
  origin       MessageOrigin     @default(SYSTEM)
  externalId   String?
  contactId    String?
  isInternal      Boolean           @default(false)
  isAiGenerated   Boolean           @default(false)
  deliveryStatus  MessageDeliveryStatus?
  createdAt       DateTime          @default(now())

  ticket      Ticket              @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender      User?               @relation("TicketMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  contact     AdditionalContact?  @relation("TicketMessageContact", fields: [contactId], references: [id], onDelete: SetNull)
  attachments Attachment[]        @relation("TicketMessageAttachments")

  @@index([ticketId, createdAt])
  @@unique([externalId, channel])
  @@map("ticket_messages")
}

model Attachment {
  id              String         @id @default(cuid())
  ticketMessageId String?
  ticketId        String?
  fileName        String
  fileSize        Int
  mimeType        String
  storagePath     String
  createdAt       DateTime       @default(now())

  ticketMessage TicketMessage? @relation("TicketMessageAttachments", fields: [ticketMessageId], references: [id], onDelete: Cascade)
  extraction    AttachmentExtraction?
  ticket        Ticket?        @relation("TicketAttachments", fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("attachments")
}

model AttachmentExtraction {
  id           String   @id @default(cuid())
  attachmentId String   @unique
  method       String   // "pdf-parse" | "ocr" | "vision" | "direct" | "spreadsheet"
  status       String   @default("pending") // "pending" | "processing" | "completed" | "failed"
  rawText      String   @db.Text
  summary      String?  @db.Text
  metadata     Json?
  confidence   Float    @default(0)
  tokenCount   Int      @default(0)
  errorMessage String?
  processingMs Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@index([attachmentId])
  @@index([status])
  @@map("attachment_extractions")
}

model Refund {
  id                 String              @id @default(cuid())
  ticketId           String
  companyId          String
  requestedById      String
  approvedById       String?
  executedById       String?
  amount             Decimal             @db.Decimal(12, 2)
  paymentMethod      RefundPaymentMethod?
  bankName           String?
  bankAgency         String?
  bankAccount        String?
  pixKey             String?
  justification      String?
  boletoId           String?
  status             RefundStatus        @default(AWAITING_APPROVAL)
  rejectionReason    String?
  requestedAt        DateTime            @default(now())
  approvedAt         DateTime?
  executedAt         DateTime?
  completedAt        DateTime?
  slaDeadline        DateTime?
  slaBreached        Boolean             @default(false)
  slaAtRisk          Boolean             @default(false)
  invoiceAction      RefundInvoiceAction?
  invoiceCancelReason String?

  ticket       Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requestedBy  User               @relation("RefundRequestedBy", fields: [requestedById], references: [id])
  approvedBy   User?              @relation("RefundApprovedBy", fields: [approvedById], references: [id])
  executedBy     User?              @relation("RefundExecutedBy", fields: [executedById], references: [id])
  attachments    RefundAttachment[]
  accountPayable AccountPayable?
  creditNote     Invoice?

  @@index([companyId, status])
  @@index([ticketId])
  @@index([companyId, status, requestedAt])
  @@map("refunds")
}

model RefundAttachment {
  id           String               @id @default(cuid())
  refundId     String
  type         RefundAttachmentType
  fileName     String
  fileSize     Int
  mimeType     String
  storagePath  String
  uploadedById String
  createdAt    DateTime             @default(now())

  refund     Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation(fields: [uploadedById], references: [id])

  @@map("refund_attachments")
}

model Proposal {
  id                String         @id @default(cuid())
  clientId          String
  status            ProposalStatus @default(DRAFT)
  paymentConditions String?
  validity          DateTime?
  observations      String?
  totalValue        Decimal        @db.Decimal(12, 2) @default(0)
  companyId         String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items    ProposalItem[]
  boletos  Boleto[]
  tickets  Ticket[] @relation("TicketProposal")
  invoices Invoice[]
  events   ProposalEvent[]

  @@index([companyId, status])
  @@index([companyId, status, createdAt])
  @@map("proposals")
}

model ProposalItem {
  id          String  @id @default(cuid())
  proposalId  String
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@map("proposal_items")
}

model ProposalEvent {
  id          String   @id @default(cuid())
  proposalId  String
  type        String   // CREATED, EMAIL_SENT, BOLETO_GENERATED, BOLETO_SENT, PAID, NFSE_EMITTED, STATUS_CHANGED
  description String
  userId      String?
  createdAt   DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, createdAt])
  @@map("proposal_events")
}

model Boleto {
  id                String       @id @default(cuid())
  proposalId        String
  bankReference     String?
  value             Decimal      @db.Decimal(12, 2)
  dueDate           DateTime
  installmentNumber Int
  status            BoletoStatus @default(GENERATED)
  companyId         String
  createdAt         DateTime     @default(now())
  providerId        String?
  gatewayId         String?
  gatewayData       Json?
  manualOverride    Boolean      @default(false)

  proposal    Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider    PaymentProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  tickets     Ticket[]  @relation("TicketBoleto")
  invoices    Invoice[]
  receivables AccountReceivable[]

  // Bug C fix: Add indexes for webhook lookups and status queries
  @@index([gatewayId])
  @@index([companyId, status])
  @@map("boletos")
}

model Invoice {
  id                  String        @id @default(cuid())
  proposalId          String?
  boletoId            String?
  clientId            String
  serviceDescription  String
  value               Decimal       @db.Decimal(12, 2)
  issRate             Decimal       @db.Decimal(5, 2) @default(0)
  status              InvoiceStatus @default(PENDING)
  nfNumber            String?
  companyId           String
  type                InvoiceType   @default(STANDARD)
  cancelledAt         DateTime?
  cancellationReason  String?
  refundId            String?       @unique
  originalInvoiceId   String?
  createdAt           DateTime      @default(now())

  proposal        Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  boleto          Boleto?   @relation(fields: [boletoId], references: [id], onDelete: SetNull)
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  refund          Refund?   @relation(fields: [refundId], references: [id], onDelete: SetNull)
  originalInvoice Invoice?  @relation("CreditNote", fields: [originalInvoiceId], references: [id], onDelete: SetNull)
  creditNotes     Invoice[] @relation("CreditNote")
  taxEntries      TaxEntry[]

  @@index([companyId, status])
  @@index([companyId, status, createdAt])
  @@map("invoices")
}

model TaxEntry {
  id        String    @id @default(cuid())
  companyId String
  invoiceId String?
  type      TaxType
  period    String
  value     Decimal   @db.Decimal(12, 2)
  dueDate   DateTime
  status    TaxStatus @default(PENDING)
  createdAt DateTime  @default(now())

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([companyId, invoiceId])
  @@index([companyId, status, dueDate])
  @@map("tax_entries")
}

model ChartOfAccounts {
  id        String      @id @default(cuid())
  code      String
  name      String
  parentId  String?
  level     Int         @default(1)
  type      AccountType
  companyId String
  createdAt DateTime    @default(now())

  parent   ChartOfAccounts?  @relation("ChartOfAccountsHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children ChartOfAccounts[] @relation("ChartOfAccountsHierarchy")
  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([code, companyId])
  @@map("chart_of_accounts")
}

model BaileysAuthState {
  id        String   @id @default(cuid())
  companyId String
  keyType   String
  keyId     String
  keyData   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, keyType, keyId])
  @@index([companyId])
  @@map("baileys_auth_state")
}

model LidMapping {
  id          String   @id @default(cuid())
  companyId   String
  lid         String
  phoneNumber String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, lid])
  @@index([companyId])
  @@map("lid_mappings")
}

model AiConfig {
  id                 String   @id @default(cuid())
  companyId          String
  channel            ChannelType?  // NULL = global default, set = channel-specific override

  // --- Existentes ---
  enabled            Boolean  @default(false)
  persona            String   @db.Text
  welcomeMessage     String?  @db.Text
  escalationKeywords String[]
  maxIterations      Int      @default(5)

  // --- Provider ---
  provider           String   @default("openai")
  apiKey             String?  @db.Text
  apiKeyHint         String?  // Last 4 chars of plaintext API key for display
  model              String?

  // --- Canais ---
  whatsappEnabled    Boolean  @default(true)
  emailEnabled       Boolean  @default(false)
  emailPersona       String?  @db.Text
  emailSignature     String?  @db.Text

  // --- Reclame Aqui ---
  raEnabled                Boolean  @default(false)
  raMode                   String   @default("suggest") // "suggest" | "auto" | "off"
  raPrivateBeforePublic    Boolean  @default(true)
  raAutoRequestEvaluation  Boolean  @default(false)
  raEscalationKeywords     String[] @default(["processo", "advogado", "procon", "judicial", "indenização"])

  // --- Limites ---
  dailySpendLimitBrl Decimal? @db.Decimal(10, 2)

  // --- Temperatura ---
  temperature        Float    @default(0.7)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  usageLogs AiUsageLog[]

  @@unique([companyId, channel]) // For non-null channels; see migration for NULL partial index
  @@map("ai_config")
}

model AiUsageLog {
  id           String   @id @default(cuid())
  aiConfigId   String
  companyId    String
  provider     String
  model        String
  channel      String
  inputTokens  Int
  outputTokens Int
  costUsd      Decimal  @db.Decimal(10, 6)
  costBrl      Decimal  @db.Decimal(10, 4)
  ticketId     String?
  isSimulation Boolean  @default(false)
  createdAt    DateTime @default(now())

  aiConfig AiConfig @relation(fields: [aiConfigId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([aiConfigId, createdAt])
  @@index([isSimulation])
  @@index([companyId, isSimulation])
  @@map("ai_usage_logs")
}


model Document {
  id        String         @id @default(cuid())
  companyId String
  name      String
  mimeType  String
  fileSize  Int
  status    DocumentStatus @default(PROCESSING)
  channel   ChannelType?   // NULL = general (all channels), set to filter by channel
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  chunks  DocumentChunk[]

  @@index([companyId, createdAt])
  @@map("documents")
}

model FiscalConfig {
  id                        String    @id @default(cuid())
  companyId                 String    @unique
  taxRegime                 TaxRegime @default(SIMPLES_NACIONAL)
  issRate                   Decimal   @db.Decimal(5, 2) @default(5)
  pisRate                   Decimal   @db.Decimal(5, 2) @default(0)
  cofinsRate                Decimal   @db.Decimal(5, 2) @default(0)
  irpjRate                  Decimal   @db.Decimal(5, 2) @default(0)
  csllRate                  Decimal   @db.Decimal(5, 2) @default(0)
  cnae                      String?
  inscricaoMunicipal        String?
  codigoMunicipio           String?
  nfseSerieNumber           String    @default("1")
  nfseNextNumber            Int       @default(1)
  nfeSerieNumber            String    @default("1")
  nfeNextNumber             Int       @default(1)
  autoEmitNfse              Boolean   @default(false)
  // NFS-e: certificado digital A1 (Campinas e São Paulo)
  certificadoPfx            String?   // base64 do .pfx encriptado via AES
  certificadoSenha          String?   // senha do .pfx encriptada via AES
  // NFS-e: tokens para municípios sem certificado (ex: Taboão da Serra / CONAM)
  certificadoToken1         String?   // token de usuário
  certificadoToken2         String?   // senha do webservice
  // NFS-e: código de serviço
  itemListaServico          String?   // código LC116 ex: "01.07"
  codigoTributacaoMunicipio String?   // código tributação opcional
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("fiscal_configs")
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  content    String   @db.Text
  embedding  Float[]
  chunkIndex Int
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_chunks")
}

model PaymentProvider {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  provider      String
  credentials   String   @db.Text
  webhookUrl    String?
  webhookSecret String?
  sandbox       Boolean  @default(false)
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company  Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rules    PaymentRoutingRule[]
  boletos  Boleto[]

  @@index([companyId, isActive])
  // ⚠️ PARTIAL UNIQUE INDEX (not expressible in Prisma schema):
  // Enforces at most one isDefault=true per company.
  // Maintained via migration 20260311000001_fix_pr35_bugs:
  //   CREATE UNIQUE INDEX "payment_providers_companyId_isDefault_unique"
  //     ON "payment_providers" ("companyId") WHERE "isDefault" = true;
  // DO NOT use @@unique([companyId, isDefault]) — that would also limit
  // isDefault=false to one per company, which is incorrect.
  // If regenerating migrations, re-add this partial index manually.
  @@map("payment_providers")
}

model PaymentRoutingRule {
  id          String      @id @default(cuid())
  providerId  String
  priority    Int         @default(0)
  clientType  ClientType?
  minValue    Decimal?    @db.Decimal(12, 2)
  maxValue    Decimal?    @db.Decimal(12, 2)
  tags        String[]
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  provider PaymentProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, priority])
  @@map("payment_routing_rules")
}

model SantanderSequence {
  id           String   @id @default(cuid())
  companyId    String
  covenantCode String
  lastNumber   Int      @default(0)
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, covenantCode])
  @@map("santander_sequences")
}
