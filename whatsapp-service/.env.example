# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mendeserp?schema=public

# WhatsApp Service
WHATSAPP_SERVICE_PORT=3001
WHATSAPP_SERVICE_API_KEY=your-api-key-here
WHATSAPP_SERVICE_BASE_URL=http://localhost:3001
