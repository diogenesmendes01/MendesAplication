WHATSAPP_MEDIA_TOKEN_SECRET=

# Webhook to ERP
WHATSAPP_WEBHOOK_URL=http://localhost:3000/api/webhooks/whatsapp
WHATSAPP_WEBHOOK_SECRET=your-webhook-secret-here
